{
  "name": "social-media-fetcher-spec-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node backend/src/server.js",
    "dev:backend": "node backend/src/server.js",
    "dev:frontend": "vite --config frontend/vite.config.js",
    "build:frontend": "vite build --config frontend/vite.config.js",
    "preview:frontend": "vite preview --config frontend/vite.config.js",
    "seed": "node backend/src/cli/seed-demo.js",
    "sign": "node backend/src/cli/sign-request.js",
    "test:backend": "node --test tests/integration/*.test.js tests/unit/*.test.js",
    "test:frontend": "vitest run --config frontend/vite.config.js",
    "test": "npm run test:backend && npm run test:frontend"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.8.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "vite": "^5.4.14",
    "vitest": "^2.1.8"
  }
}
